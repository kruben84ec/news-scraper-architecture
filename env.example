# =============================================================
# .env.example — Plantilla de configuración
# Copia este archivo como .env y completa los valores reales.
#
#   cp .env.example .env
#
# NUNCA subas .env al repositorio. Solo .env.example va a Git.
# =============================================================


# -------------------------------------------------------------
# REQUERIDO — Sin este valor el script lanza un error y termina
# -------------------------------------------------------------

# URL completa del sitio que se va a scrapear.
# Debe incluir el protocolo (https://).
# Ejemplo real: https://www.eluniverso.com
SCRAPER_URL=https://www.ejemplo.com


# -------------------------------------------------------------
# SALIDA DE DATOS
# -------------------------------------------------------------

# Ruta relativa donde se guardará el JSON con los artículos.
# El directorio se crea automáticamente si no existe.
# Default: data/news.json
OUTPUT_FILE=data/news.json


# -------------------------------------------------------------
# LOGGING
# -------------------------------------------------------------

# Ruta del archivo de log. Se escribe en modo append.
# También se imprime en consola simultáneamente.
# Default: scraper.log
LOG_FILE=scraper.log

# Nivel de detalle del log.
# Opciones: DEBUG | INFO | WARNING | ERROR
#   DEBUG   → muestra todo, útil durante desarrollo
#   INFO    → ejecución normal (recomendado en producción)
#   WARNING → solo advertencias y errores
#   ERROR   → solo errores críticos
# Default: INFO
LOG_LEVEL=INFO


# -------------------------------------------------------------
# SOLICITUD HTTP
# -------------------------------------------------------------

# Segundos máximos de espera para la respuesta del servidor.
# Si el servidor no responde en este tiempo, la ejecución falla.
# Aumentar si el sitio objetivo es lento. Bajar para fallar rápido.
# Default: 10
REQUEST_TIMEOUT=10

# Cadena User-Agent enviada en la cabecera HTTP.
# Algunos sitios bloquean scrapers si no parece un navegador real.
# Puedes copiar el User-Agent de tu navegador desde DevTools > Network.
# Default: Mozilla/5.0
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36


# -------------------------------------------------------------
# EXTRACCIÓN DE CONTENIDO
# -------------------------------------------------------------

# Selector CSS que BeautifulSoup usará para encontrar los artículos.
# Se aplica sobre el HTML completo de la página.
# Ejemplos comunes:
#   h2 a         → enlaces dentro de títulos H2 (default)
#   article h3 a → H3 dentro de etiquetas <article>
#   .card-title a → enlaces con clase card-title
# Verificar con DevTools del navegador si el sitio cambia su estructura.
# Default: h2 a
CSS_SELECTOR=h2 a


# -------------------------------------------------------------
# VALIDACIÓN DE CALIDAD
# -------------------------------------------------------------

# Tamaño mínimo en bytes que debe tener el HTML descargado.
# Si el HTML es más pequeño, probablemente hubo un error o redirección.
# Para páginas ligeras bajar a 500. Para portadas de noticias, 3000+.
# Default: 1000
MIN_HTML_SIZE=1000

# Número mínimo de artículos que deben encontrarse para considerar
# la ejecución válida. Si se encuentran menos, no se guarda nada.
# Útil para detectar cambios en la estructura HTML del sitio.
# Default: 1
MIN_ARTICLES=1


# -------------------------------------------------------------
# CONTROL DE EJECUCIÓN (anti-flood)
# -------------------------------------------------------------

# Ruta del archivo JSON que registra el historial de ejecuciones.
# Se usa para calcular si ha pasado suficiente tiempo desde la última vez.
# Default: execution_log.json
EXECUTION_LOG_FILE=execution_log.json

# Intervalo mínimo en segundos entre ejecuciones consecutivas.
# Si el scraper se ejecuta antes de que pase este tiempo, se cancela.
# Referencia de valores:
#   60   →  1 minuto  (desarrollo / pruebas)
#   300  →  5 minutos (default)
#   3600 →  1 hora    (producción ligera)
#   86400 → 1 día     (scraping diario)
# Default: 300
MIN_INTERVAL_SECONDS=300
